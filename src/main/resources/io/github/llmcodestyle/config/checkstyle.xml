<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
        "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
        "https://checkstyle.org/dtds/configuration_1_3.dtd">

<module name="Checker">
    <property name="charset" value="UTF-8"/>
    <property name="severity" value="error"/>

    <!-- Path-based scoping using inline SuppressionSingleFilter.
         NoSystemOutInProductionCheck — main only (skip test sources).
         TestClassNamingCheck and LongTestLiteralCheck — test only (skip main sources). -->
    <module name="SuppressionSingleFilter">
        <property name="checks" value="NoSystemOutInProductionCheck"/>
        <property name="files" value="[\\/]src[\\/]test[\\/]"/>
    </module>
    <module name="SuppressionSingleFilter">
        <property name="checks" value="TestClassNamingCheck"/>
        <property name="files" value="[\\/]src[\\/]main[\\/]"/>
    </module>
    <module name="SuppressionSingleFilter">
        <property name="checks" value="LongTestLiteralCheck"/>
        <property name="files" value="[\\/]src[\\/]main[\\/]"/>
    </module>
    <module name="SuppressionSingleFilter">
        <property name="checks" value="PublicMethodTestCoverageCheck"/>
        <property name="files" value="[\\/]src[\\/]test[\\/]"/>
    </module>

    <!-- File-level checks -->
    <module name="FileTabCharacter">
        <property name="eachLine" value="true"/>
    </module>
    <module name="NewlineAtEndOfFile"/>
    <module name="FileLength">
        <property name="max" value="350"/>
    </module>
    <module name="LineLength">
        <property name="max" value="180"/>
        <property name="ignorePattern" value="^package.*|^import.*|a]+ href|href|http://|https://|ftp://"/>
    </module>

    <module name="TreeWalker">
        <module name="MagicNumber">
            <property name="ignoreNumbers" value="-1, 0, 1, 2"/>
            <property name="ignoreAnnotation" value="true"/>
        </module>
        <module name="MatchXpath">
            <property name="query" value="//METHOD_CALL[DOT/IDENT[@text='sleep'] and DOT/IDENT[@text='Thread']]"/>
            <message key="matchxpath.match" value="Thread.sleep detected. Consider using java.util.concurrent synchronization utilities."/>
        </module>

        <!-- Naming -->
        <module name="ConstantName"/>
        <module name="LocalVariableName"/>
        <module name="MemberName"/>
        <module name="MethodName"/>
        <module name="PackageName"/>
        <module name="ParameterName"/>
        <module name="TypeName"/>
        <module name="LambdaParameterName"/>
        <module name="PatternVariableName"/>
        <module name="RecordComponentName"/>

        <!-- Imports -->
        <module name="AvoidStarImport"/>
        <module name="RedundantImport"/>
        <module name="UnusedImports"/>
        <module name="IllegalImport"/>

        <!-- Size -->
        <module name="MethodLength">
            <property name="max" value="50"/>
        </module>
        <module name="ParameterNumber">
            <property name="max" value="10"/>
        </module>
        <module name="OuterTypeNumber"/>
        <module name="AnonInnerLength">
            <property name="max" value="30"/>
        </module>

        <!-- Whitespace -->
        <module name="EmptyForIteratorPad"/>
        <module name="GenericWhitespace"/>
        <module name="MethodParamPad"/>
        <module name="NoWhitespaceAfter"/>
        <module name="NoWhitespaceBefore"/>
        <module name="ParenPad"/>
        <module name="WhitespaceAfter"/>
        <module name="WhitespaceAround">
            <property name="allowEmptyConstructors" value="true"/>
            <property name="allowEmptyMethods" value="true"/>
            <property name="allowEmptyTypes" value="true"/>
        </module>
        <module name="SingleSpaceSeparator"/>
        <module name="EmptyLineSeparator">
            <property name="allowNoEmptyLineBetweenFields" value="true"/>
            <property name="allowMultipleEmptyLines" value="false"/>
        </module>
        <module name="NoLineWrap"/>
        <module name="OperatorWrap"/>
        <module name="SeparatorWrap">
            <property name="tokens" value="COMMA"/>
            <property name="option" value="eol"/>
        </module>

        <!-- Blocks -->
        <module name="AvoidNestedBlocks"/>
        <module name="EmptyBlock"/>
        <module name="LeftCurly"/>
        <module name="NeedBraces"/>
        <module name="RightCurly"/>

        <!-- Nesting limits -->
        <module name="NestedIfDepth">
            <property name="max" value="2"/>
        </module>
        <module name="NestedForDepth">
            <property name="max" value="3"/>
        </module>
        <module name="NestedTryDepth">
            <property name="max" value="3"/>
        </module>

        <!-- Coding -->
        <module name="EmptyStatement"/>
        <module name="EqualsHashCode"/>
        <module name="EqualsAvoidNull"/>
        <module name="MissingSwitchDefault"/>
        <module name="SimplifyBooleanExpression"/>
        <module name="SimplifyBooleanReturn"/>
        <module name="StringLiteralEquality"/>
        <module name="OneStatementPerLine"/>
        <module name="MultipleVariableDeclarations"/>
        <module name="CovariantEquals"/>
        <module name="DeclarationOrder"/>
        <module name="DefaultComesLast"/>
        <module name="FallThrough"/>
        <module name="IllegalCatch">
            <property name="illegalClassNames" value="java.lang.Error, java.lang.Throwable"/>
        </module>
        <module name="IllegalThrows">
            <property name="illegalClassNames" value="java.lang.Error, java.lang.Throwable"/>
        </module>
        <module name="InnerAssignment"/>
        <module name="MutableException"/>
        <module name="NoFinalizer"/>
        <module name="PackageDeclaration"/>
        <module name="SuperClone"/>
        <module name="SuperFinalize"/>
        <module name="UnnecessaryParentheses"/>
        <module name="UnnecessarySemicolonAfterOuterTypeDeclaration"/>
        <module name="UnnecessarySemicolonAfterTypeMemberDeclaration"/>
        <module name="UnnecessarySemicolonInEnumeration"/>
        <module name="UnnecessarySemicolonInTryWithResources"/>
        <module name="OverloadMethodsDeclarationOrder"/>

        <!-- Annotations -->
        <module name="AnnotationLocation">
            <property name="allowSamelineSingleParameterlessAnnotation" value="false"/>
            <property name="allowSamelineParameterizedAnnotation" value="false"/>
            <property name="allowSamelineMultipleAnnotations" value="false"/>
            <property name="tokens" value="CLASS_DEF, INTERFACE_DEF, PACKAGE_DEF, ENUM_CONSTANT_DEF, ENUM_DEF, METHOD_DEF, CTOR_DEF, RECORD_DEF, COMPACT_CTOR_DEF, ANNOTATION_DEF, ANNOTATION_FIELD_DEF, VARIABLE_DEF"/>
        </module>
        <module name="MissingOverride"/>

        <!-- Modifiers -->
        <module name="ModifierOrder"/>
        <module name="RedundantModifier"/>

        <!-- Metrics -->
        <module name="BooleanExpressionComplexity">
            <property name="max" value="5"/>
        </module>
        <module name="CyclomaticComplexity">
            <property name="max" value="15"/>
        </module>

        <!-- Custom checks: layout -->
        <module name="io.github.llmcodestyle.layout.UnnecessaryLineWrapCheck">
            <property name="maxLineLength" value="180"/>
        </module>
        <module name="io.github.llmcodestyle.layout.ChainedCallLineBreakCheck">
            <property name="minChainLength" value="4"/>
        </module>
        <module name="io.github.llmcodestyle.layout.StaticFinalFirstCheck"/>
        <module name="io.github.llmcodestyle.layout.MethodCallArgumentsOnSameLineCheck"/>
        <module name="io.github.llmcodestyle.layout.CompactableParameterListCheck">
            <property name="maxLineLength" value="180"/>
        </module>
        <module name="io.github.llmcodestyle.layout.ArrayInitSpaceCheck"/>

        <!-- Custom checks: forbidden -->
        <module name="io.github.llmcodestyle.forbidden.NoSuppressionCheck"/>
        <module name="io.github.llmcodestyle.forbidden.ForbiddenGenericCatchCheck"/>
        <module name="io.github.llmcodestyle.forbidden.NoSystemOutInProductionCheck"/>
        <module name="io.github.llmcodestyle.forbidden.ForbidAssertKeywordCheck"/>

        <!-- Custom checks: quality -->
        <module name="io.github.llmcodestyle.quality.TestMethodNameCheck"/>
        <module name="io.github.llmcodestyle.quality.TestClassNamingCheck"/>
        <module name="io.github.llmcodestyle.quality.UnusedPrivateMembersCheck"/>
        <module name="io.github.llmcodestyle.quality.LongTestLiteralCheck">
            <property name="maxLength" value="80"/>
        </module>
        <module name="io.github.llmcodestyle.quality.UtilClassInUtilsPackageCheck"/>
        <module name="io.github.llmcodestyle.quality.PublicMethodTestCoverageCheck"/>
        <module name="io.github.llmcodestyle.quality.TestOnlyDelegateCheck"/>

        <!-- Custom checks: simplify -->
        <module name="io.github.llmcodestyle.simplify.InlineRegexConstantCheck"/>
        <module name="io.github.llmcodestyle.simplify.StaticImportCandidateCheck"/>
        <module name="io.github.llmcodestyle.simplify.IndexOfToContainsCheck"/>
        <module name="io.github.llmcodestyle.simplify.UseIsEmptyCheck"/>
        <module name="io.github.llmcodestyle.simplify.CollapsibleConstantConcatenationCheck"/>
        <module name="io.github.llmcodestyle.simplify.SingleUseLocalVariableCheck"/>
        <module name="io.github.llmcodestyle.simplify.PureSingleUseLocalVariableCheck"/>

        <!-- Miscellaneous -->
        <module name="ArrayTypeStyle"/>
        <module name="UpperEll"/>
        <module name="Indentation">
            <property name="basicOffset" value="4"/>
            <property name="caseIndent" value="4"/>
            <property name="lineWrappingIndentation" value="4"/>
            <property name="forceStrictCondition" value="false"/>
        </module>
        <module name="CommentsIndentation"/>
        <module name="TrailingComment"/>
        <module name="FinalClass"/>
        <module name="HideUtilityClassConstructor"/>
        <module name="OuterTypeFilename"/>
        <module name="OneTopLevelClass"/>
        <module name="HiddenField">
            <property name="tokens" value="VARIABLE_DEF"/>
        </module>
        <module name="EmptyCatchBlock">
            <property name="exceptionVariableName" value="expected|ignored"/>
        </module>

        <!-- Javadoc -->
        <module name="JavadocStyle">
            <property name="checkFirstSentence" value="false"/>
        </module>
        <module name="AtclauseOrder">
            <property name="tagOrder" value="@param, @return, @throws, @deprecated"/>
        </module>
    </module>

    <!-- File-level custom checks -->
    <module name="io.github.llmcodestyle.forbidden.CommentedOutCodeCheck">
        <property name="minConsecutiveLines" value="2"/>
        <property name="fileExtensions" value="java"/>
    </module>
    <module name="io.github.llmcodestyle.layout.BlankLineAfterCommentCheck">
        <property name="fileExtensions" value="java"/>
    </module>
    <module name="io.github.llmcodestyle.forbidden.UnicodeEscapeCheck">
        <property name="fileExtensions" value="java"/>
    </module>

    <!-- Regexp checks -->
    <module name="RegexpSingleline">
        <property name="format" value="public.*class \S*?Utils \{"/>
        <property name="message" value="Util class must not have 's' ending — use *Util not *Utils"/>
    </module>
    <module name="RegexpSingleline">
        <property name="format" value="class \S*?Helper[\s&lt;]"/>
        <property name="message" value="Utility class should end with *Util not *Helper"/>
    </module>
    <module name="RegexpSingleline">
        <property name="format" value="class \S*?Validator[\s&lt;]"/>
        <property name="message" value="Utility class should end with *Util not *Validator (unless it's a Spring Validator)"/>
    </module>
    <module name="RegexpMultiline">
        <property name="format" value=".*(interface|class|enum)\s.*\{\n.*\w+"/>
        <property name="message" value="Blank line should be added at start of the type code block"/>
        <property name="fileExtensions" value="java"/>
    </module>
    <module name="RegexpMultiline">
        <property name="format" value="/\*\*\n\s+\* .+\n\s+\* [^@]"/>
        <property name="message" value="Multi-line javadoc — condense to single line: /** Does X. */"/>
        <property name="fileExtensions" value="java"/>
    </module>
    <module name="RegexpMultiline">
        <property name="format" value="/\*\*\n\s+\* [^@\n]+\n\s+\*/"/>
        <property name="message" value="Single-content javadoc should be on one line: /** Does X. */"/>
        <property name="fileExtensions" value="java"/>
    </module>
</module>
